    style.
      .glass {
        background: rgba(45, 52, 73, 0.4);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        }
        .hero-gradient {
          background: radial-gradient(circle at 50% 50%, rgba(128, 131, 255, 0.15) 0%, rgba(11, 19, 38, 0.6) 100%);
        }

        .text-glow {
          text-shadow: 0 0 20px rgba(192, 193, 255, 0.4);
        }
        .material-symbols-outlined {
          font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        ::-webkit-scrollbar {
          width: 6px;
          height: 6px;
        }
        ::-webkit-scrollbar-thumb {
          background: #464554;
          border-radius: 10px;
        }
        ::-webkit-scrollbar-track {
          background: transparent;
        }

    //- 4. Custom CSS
    
    link(rel="stylesheet" href="/client/css/style.css")

  body(
    hx-boost="true"
    hx-target="#app-shell"
    hx-select="#app-shell"
    class="bg-surface text-on-surface font-body selection:bg-secondary selection:text-on-secondary"
    data-user-authenticated=(isAuthenticated ? "1" : "0")
  )

    #app-shell
      include ../partials/header.pug

      main#main-content(class="pt-0 min-h-screen overflow-x-hidden w-full relative pb-32")
        block main

      include ../partials/footer.pug

    include ../partials/player.pug

