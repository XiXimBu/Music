header(class="sticky top-0 z-50 w-full bg-zinc-900/60 backdrop-blur-xl border-b border-white/5 shadow-[0_8px_32px_rgba(0,0,0,0.5)] flex justify-between items-center px-6 h-16")
  //- Bên trái: Logo và Search
  div(class="flex items-center gap-8")
