//- partials/sider.pug — href + data-sider-nav; trạng thái active do handle.sider.js theo pathname

//- Nút Toggle dành riêng cho Mobile (Hiện khi màn hình < 768px)
button(
  id="toggleSidebar"
  class="fixed bottom-4 right-4 z-50 p-3 bg-primary text-on-primary rounded-full shadow-2xl md:hidden flex items-center justify-center"
  onclick="document.getElementById('sidebar').classList.toggle('-translate-x-full')"
)
  span(class="material-symbols-outlined") menu

//- Overlay cho Mobile (Làm mờ nền khi mở sidebar)
div(
  id="sidebarOverlay"
  class="fixed inset-0 bg-black/60 backdrop-blur-sm z-30 hidden transition-opacity md:hidden"
  onclick="document.getElementById('sidebar').classList.add('-translate-x-full')"
)

//- SideNavBar
aside(
  id="sidebar"
  class="h-screen w-64 fixed left-0 top-0 z-40 bg-zinc-950 flex flex-col gap-2 p-4 pt-20 border-r border-white/5 transition-transform duration-300 transform -translate-x-full md:translate-x-0"
)
  //- Logo Area
  div(class="mb-8 pt-2 px-2 flex justify-between items-center")
    div(class="flex items-center gap-3")
      div(class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center shadow-[0_0_20px_rgba(166,197,250,0.3)]")
        span(class="material-symbols-outlined text-on-primary", style="font-variation-settings: 'FILL' 1;") music_note
      div
        h2(class="text-xl font-black text-white font-headline leading-tight") Xi
        p(class="text-xs text-zinc-500 font-body") Admin Suite

    //- Nút đóng sidebar (chỉ hiện trên mobile)
    button(class="md:hidden text-zinc-400" onclick="document.getElementById('sidebar').classList.add('-translate-x-full')")
      span(class="material-symbols-outlined") close

  //- Navigation Links (mặc định inactive; handle.sider.js gán active theo URL)
  nav(class="flex-1 space-y-1 overflow-y-auto no-scrollbar")
    a(
      href="/admin/dashboard"
      data-sider-nav="dashboard"
      class="flex items-center gap-3 px-4 py-3 text-zinc-500 hover:text-zinc-200 hover:bg-zinc-900 rounded-full transition-all duration-300 group"
    )
      span(class="material-symbols-outlined group-hover:translate-x-1 duration-200", data-icon="dashboard") dashboard
      span(class="font-inter text-sm tracking-wide font-medium") Dashboard

    mixin navItem(icon, label, href="#", navKey=null)
      if navKey
        a(
          href=href
          data-sider-nav=navKey
          class="flex items-center gap-3 px-4 py-3 text-zinc-500 hover:text-zinc-200 hover:bg-zinc-900 rounded-full transition-all duration-300 group"
        )
          span(class="material-symbols-outlined group-hover:translate-x-1 duration-200", data-icon=icon)= icon
          span(class="font-inter text-sm tracking-wide")= label
      else
        a(
          href=href
          class="flex items-center gap-3 px-4 py-3 text-zinc-500 hover:text-zinc-200 hover:bg-zinc-900 rounded-full transition-all duration-300 group"
        )
          span(class="material-symbols-outlined group-hover:translate-x-1 duration-200", data-icon=icon)= icon
          span(class="font-inter text-sm tracking-wide")= label

    +navItem("music_note", "Manage Songs", "/admin/song", "songs")
    +navItem("mic_external_on", "Artists", "/admin/artist", "artists")
    +navItem("album", "Albums", "#", null)
    +navItem("category", "Genres", "#", null)
    +navItem("group", "Users", "#", null)

  //- Footer Actions
  div(class="mt-auto pt-4 border-t border-white/5 space-y-1")
    a(
      href="/admin/song/create"
      data-sider-nav="song-create"
      class="w-full mb-4 py-3 px-4 bg-gradient-to-r from-primary to-primary-container text-on-primary font-bold rounded-xl shadow-lg shadow-primary/20 hover:scale-[1.02] active:scale-95 transition-all flex items-center justify-center gap-2"
    )
      span(class="material-symbols-outlined text-sm") add_circle
      span(class="text-sm") Add New Track

    a(href="#", class="flex items-center gap-3 px-4 py-3 text-zinc-500 hover:text-zinc-200 hover:bg-zinc-900 rounded-full transition-all duration-300")
      span(class="material-symbols-outlined", data-icon="help") help
      span(class="font-inter text-sm tracking-wide") Support

    a(href="#", class="flex items-center gap-3 px-4 py-3 text-zinc-500 hover:text-zinc-200 hover:bg-zinc-900 rounded-full transition-all duration-300")
      span(class="material-symbols-outlined", data-icon="logout") logout
      span(class="font-inter text-sm tracking-wide") Logout
