//- Tránh đóng thẻ script sớm: escape ký tự < trong JSON.
#toast-container(
  class="fixed top-5 right-5 z-[100] flex flex-col gap-3 items-end pointer-events-none max-w-sm w-[calc(100%-2.5rem)] sm:w-96",
  aria-live="polite",
  aria-atomic="true"
)
