extends ../../layouts/authen.pug

block main
  div.w-full.max-w-xl.glass.rounded-xl.p-8.relative.z-10.secondary-glow(class="md:p-12")
    div.text-center.mb-10
      h1.font-headline.font-extrabold.text-4xl.mb-3.text-on-surface.tracking-tight Đặt Lại Mật Khẩu
      p.text-on-surface-variant.text-sm.font-medium Nhập mật khẩu mới cho tài khoản của bạn.

    form.space-y-6(action="/auth/reset-password" method="POST")
      input(type="hidden" name="resetToken" value=resetToken)

      div.relative.group
        div.absolute.inset-y-0.left-0.pl-4.flex.items-center.pointer-events-none.text-outline(class="group-focus-within:text-secondary transition-colors")
          span.material-symbols-outlined(style="font-size: 20px") lock
        input#password.w-full.bg-surface-container-low.text-on-surface.text-sm.rounded-xl.pl-12.pr-4.py-4.transition-all.input-focus-glow(
          name="password"
          type="password"
          placeholder="Mật khẩu mới"
          class="border-outline-variant/30 focus:ring-0 focus:border-secondary placeholder:text-outline"
        )

      div.relative.group
        div.absolute.inset-y-0.left-0.pl-4.flex.items-center.pointer-events-none.text-outline(class="group-focus-within:text-secondary transition-colors")
          span.material-symbols-outlined(style="font-size: 20px") lock_reset
        input#confirmPassword.w-full.bg-surface-container-low.text-on-surface.text-sm.rounded-xl.pl-12.pr-4.py-4.transition-all.input-focus-glow(
          name="confirmPassword"
          type="password"
          placeholder="Xác nhận mật khẩu mới"
          class="border-outline-variant/30 focus:ring-0 focus:border-secondary placeholder:text-outline"
        )

      button.w-full.py-4.rounded-xl.transition-all.font-headline.text-lg(
        type="submit"
        class="bg-gradient-to-r from-secondary to-primary-container text-on-primary font-bold hover:scale-[1.02] active:scale-95 hover:shadow-[0_0_25px_rgba(68,226,205,0.4)]"
      ) Cập nhật mật khẩu
