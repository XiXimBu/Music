extends ../../layouts/default.pug


block main
  main.pt-16.flex-grow
    // Profile Header
    section.relative.w-full.py-16.px-6.hero-gradient.overflow-hidden(class="md:px-12")
      div.max-w-7xl.mx-auto.flex.flex-col.items-center.gap-8.relative.z-10(class="md:flex-row md:gap-12")
        // Avatar with Neon Glow
        div.relative.group
          div.absolute.inset-0.bg-gradient-to-tr.from-primary.to-secondary.rounded-full.blur-2xl.opacity-40.transition-opacity(class="group-hover:opacity-60")
          div.relative.w-48.h-48.rounded-full.p-1(class="md:w-56 md:h-56 border-4 border-secondary/20")
            img#profileAvatar.w-full.h-full.object-cover.rounded-full(
              src=(user && user.avatar) ? user.avatar : "https://cdn-icons-png.flaticon.com/512/149/149071.png"
              alt="User Avatar"
            )
          input#editAvatar.hidden.mt-4.block.w-full.text-sm.text-on-surface(type="file" name="avatar" accept="image/*")

        // Profile Info
        div.flex-1.text-center(class="md:text-left")
          h1#profileName.text-4xl.font-extrabold.text-on-surface.mb-2.tracking-tight.text-glow(class="md:text-6xl font-headline")= (user && user.fullName) ? user.fullName : "User"
          input#editFullName.hidden.w-full.rounded-lg.bg-surface-container-low.border-outline-variant.text-on-surface.mb-3(
            type="text"
            name="fullName"
            value=(user && user.fullName) ? user.fullName : ""
            placeholder="Your name"
          )
          p#profileDescription.text-on-surface-variant.text-lg.mb-6.font-medium.max-w-lg(class="md:text-xl")= (user && user.description) ? user.description : "Losing myself in the beats of the night. 🌙"
          textarea#editDescription.hidden.w-full.rounded-lg.bg-surface-container-low.border-outline-variant.text-on-surface.mb-6(
            name="description"
            rows="4"
            placeholder="Share your vibe..."
          )= (user && user.description) ? user.description : ""
          
          div.flex.flex-wrap.justify-center.gap-6.mb-8(class="md:justify-start")
            div.flex.flex-col
              span.text-secondary.font-bold.text-xl 12
              span.font-bold.uppercase.tracking-wider.text-on-surface-variant(class="text-[10px]") Playlists
            div.flex.flex-col
              span.text-secondary.font-bold.text-xl 482
              span.font-bold.uppercase.tracking-wider.text-on-surface-variant(class="text-[10px]") Liked Songs
            div.flex.flex-col
              span.text-secondary.font-bold.text-xl 1.2K
              span.font-bold.uppercase.tracking-wider.text-on-surface-variant(class="text-[10px]") Followers
          
          div.flex.flex-wrap.justify-center.gap-4(class="md:justify-start")
            form(action="/auth/logout" method="POST" data-turbo="false")
              button.px-8.py-3.bg-gradient-to-r.from-secondary.to-secondary-container.text-on-secondary.font-bold.rounded-xl.transition-transform.secondary-glow(type="submit" class="hover:scale-105 active:scale-95") Log out
            button#openEditProfile.px-8.py-3.border.text-on-surface.font-bold.rounded-xl.transition-colors(type="button" class="border-outline-variant/30 hover:bg-surface-container-high") Edit Profile
            button#cancelEditProfile.hidden.px-8.py-3.border.text-on-surface.font-bold.rounded-xl.transition-colors(type="button" class="border-outline-variant/30 hover:bg-surface-container-high") Cancel

    // Favorite Artists
    section.mt-12.px-6.max-w-7xl.mx-auto(class="md:px-12")
      div.flex.justify-between.items-end.mb-8
        h2.text-2xl.font-bold.tracking-tight(class="md:text-3xl") Your Artists
        

      if followedArtists && followedArtists.length
        div.flex.gap-6.overflow-x-auto.pb-8.scrollbar-hide.no-scrollbar
          each artist in followedArtists
            a.flex-shrink-0.group.cursor-pointer(
              href=artist.slug ? `/artist/detail/${artist.slug}` : "#"
              aria-label=`Xem nghệ sĩ ${artist.name}`
            )
              div.relative.w-36.h-36.mb-4(class="md:w-44 md:h-44")
                div.absolute.inset-0.rounded-full.scale-0.transition-transform.duration-300(class="bg-primary/20 group-hover:scale-110")
                img.w-full.h-full.object-cover.rounded-full.border-2.transition-all.duration-300(
                  src=artist.avatar
                  alt=artist.name
                  class="border-primary/20 group-hover:border-primary"
                )
                div.absolute.inset-0.flex.items-center.justify-center.opacity-0.transition-opacity(class="group-hover:opacity-100")
                  div.w-12.h-12.bg-secondary.text-on-secondary.rounded-full.flex.items-center.justify-center.shadow-lg
                    span.material-symbols-outlined(style="font-variation-settings: 'FILL' 1;") play_arrow
              p.text-center.font-bold.text-on-surface.transition-colors(class="group-hover:text-primary")= artist.name
      else
        p.text-on-surface-variant Bạn chưa theo dõi nghệ sĩ nào.

    // User Playlists Grid
    section.mt-16.px-6.max-w-7xl.mx-auto(class="md:px-12")
      .flex.items-center.justify-between.gap-4.mb-8
        h2.text-2xl.font-bold.tracking-tight(class="md:text-3xl") Your Playlists
        button#openCreatePlaylistModal.text-sm.font-bold.uppercase.tracking-widest.text-primary(type="button" class="hover:underline") Tao Playlist moi
      if playlists && playlists.length
        #playlistGrid.flex.gap-6.overflow-x-auto.pb-4(class="snap-x snap-mandatory no-scrollbar")
          each playlist in playlists
            div.glass.p-5.rounded-xl.transition-all.duration-300.playlist-card.flex-none(
              data-playlist-id=playlist._id
              class="w-[320px] snap-start hover:scale-[1.02] hover:bg-surface-container-highest/60 hover:shadow-[0_0_30px_rgba(192,193,255,0.15)]"
            )
              .flex.items-center.justify-between.gap-3.mb-1
                h3.text-xl.font-bold.text-on-surface(data-playlist-title)= playlist.title
                .flex.items-center.gap-2
                  button.text-xs.font-bold.px-3.py-1.rounded-full.border.border-outline-variant.text-on-surface-variant(
                    type="button"
                    data-select-add-playlist
                    data-playlist-id=playlist._id
                  ) Chọn làm playlist thêm
                  details.relative
                    summary.w-8.h-8.flex.items-center.justify-center.rounded-full.cursor-pointer.text-on-surface-variant(
                      class="hover:bg-surface-container-high list-none"
                    )
                      span.material-symbols-outlined more_vert
                    .absolute.right-0.top-10.w-28.rounded-lg.border.border-outline-variant.bg-surface-container-high.shadow-xl.z-10.overflow-hidden
                      button.w-full.text-left.px-3.py-2.text-xs.font-bold.text-on-surface-variant(
                        type="button"
                        data-edit-playlist
                        class="hover:bg-surface-container-highest"
                      ) Sua
                      button.w-full.text-left.px-3.py-2.text-xs.font-bold.text-error(
                        type="button"
                        data-delete-playlist
                        class="hover:bg-surface-container-highest"
                      ) Xoa
              p.text-sm.text-on-surface-variant.mb-4(data-playlist-description)= playlist.description || "No description"
              form.hidden.space-y-2(data-edit-playlist-form)
                input.w-full.rounded-md.bg-surface-container-low.border-outline-variant.text-on-surface.px-3.py-2(
                  type="text"
                  data-edit-playlist-title
                  value=playlist.title
                  placeholder="Ten playlist"
                )
                textarea.w-full.rounded-md.bg-surface-container-low.border-outline-variant.text-on-surface.px-3.py-2(
                  rows="2"
                  data-edit-playlist-description
                  placeholder="Mo ta"
                )= playlist.description || ""
                .flex.items-center.gap-2
                  button.px-3.py-1.text-xs.font-bold.rounded-md.bg-secondary.text-on-secondary(type="button" data-save-playlist) Lưu
                  button.px-3.py-1.text-xs.font-bold.rounded-md.border.border-outline-variant.text-on-surface-variant(type="button" data-cancel-edit-playlist) Huy
              if playlist.songs && playlist.songs.length
                ul.space-y-4.overflow-y-auto.pr-2.no-scrollbar(class="max-h-[450px]" data-play-queue data-play-context="playlist" data-play-context-id=String(playlist._id))
                  each song, index in playlist.songs
                    li.relative.group
                      //- Hiệu ứng đổ bóng gradient nền khi hover cả dòng
                      div(class="absolute -inset-0.5 bg-gradient-to-r from-secondary to-primary opacity-0 blur rounded-xl transition-opacity group-hover:opacity-20")
                      
                      div(class="relative glass rounded-xl p-3 flex items-center gap-4 transition-colors hover:bg-surface-container-highest/60")
                        
                        //- Số thứ tự
                        span.font-black.text-xl.text-secondary.w-6.text-center.italic= index + 1      
                        button.relative.w-14.h-14.rounded-lg.overflow-hidden.flex-shrink-0(
                          type="button"
                          button-play-track=song.audioUrl
                          data-audio-url=song.audioUrl
                          data-song-id=song._id
                          data-song-title=song.title
                          data-song-artist=song.artistNames
                          data-song-cover=(song.coverImage || "https://cdn-icons-png.flaticon.com/512/727/727245.png")
                          class="group/playbtn transition-transform active:scale-90"
                        )
                          //- Ảnh nền của bài hát
                          img.w-full.h-full.object-cover(
                            src=song.coverImage || "https://cdn-icons-png.flaticon.com/512/727/727245.png"
                            alt=song.title
                          )
                          //- Lớp phủ Overlay hiện Icon Play khi hover (vào item hoặc vào chính ảnh)
                          div(class="absolute inset-0 bg-black/40 flex items-center justify-center opacity-0 transition-opacity group-hover:opacity-100")
                            span.material-symbols-outlined.text-white(style="font-size: 32px; font-variation-settings: 'FILL' 1;") play_arrow

                        //- Thông tin bài hát
                        div.flex-1.min-w-0
                          h4.text-sm.font-bold.text-on-surface.truncate(class="mb-0.5")= song.title
                          p.text-xs.text-on-surface-variant.truncate= song.artistNames

                        //- Nút Gỡ khỏi playlist
                        button.flex-shrink-0.w-8.h-8.rounded-full.flex.items-center.justify-center.text-on-surface-variant.transition-colors(
                          type="button"
                          title="Gỡ khỏi playlist"
                          data-remove-song-from-playlist
                          data-playlist-id=playlist._id
                          data-song-id=song._id
                          class="hover:bg-error/20 hover:text-error"
                        )
                          span.material-symbols-outlined(style="font-size: 20px") close
              else
                p.text-sm.text-on-surface-variant Playlist này chưa có bài hát.
      else
        #playlistEmptyState.glass.p-5.rounded-xl
          p.text-on-surface-variant Bạn chưa có playlist nào.

    #createPlaylistModal.hidden.fixed.inset-0.items-center.justify-center.p-4(class="z-[80] bg-black/60")
      .w-full.max-w-md.rounded-xl.bg-surface-container-high.p-5
        h3.text-lg.font-bold.mb-4.text-on-surface Tao Playlist moi
        form.space-y-3
          input#createPlaylistTitle.w-full.rounded-md.bg-surface-container-low.border-outline-variant.text-on-surface.px-3.py-2(
            type="text"
            placeholder="Ten playlist"
          )
          textarea#createPlaylistDescription.w-full.rounded-md.bg-surface-container-low.border-outline-variant.text-on-surface.px-3.py-2(
            rows="3"
            placeholder="Mo ta"
          )
          .flex.items-center.gap-2.justify-end
            button#cancelCreatePlaylist.px-3.py-2.text-sm.font-bold.rounded-md.border.border-outline-variant.text-on-surface-variant(type="button") Huy
            button#createPlaylistSubmit.px-4.py-2.text-sm.font-bold.rounded-md.bg-secondary.text-on-secondary(type="button") Tao

    // Top Songs
    section.mt-16.px-6.max-w-7xl.mx-auto(class="md:px-12")
      h2.text-2xl.font-bold.tracking-tight.mb-8(class="md:text-3xl") Top Songs You Listen Most
      if topSongs && topSongs.length
        - const topSong = topSongs[0]
        .glass.rounded-xl.p-4.flex.items-center.gap-4
          .w-8.text-secondary.font-bold.text-center 1
          if topSong.song && topSong.song.coverImage
            img.w-12.h-12.rounded-lg.object-cover(src=topSong.song.coverImage alt=topSong.song.title || "Song cover")
          else
            .w-12.h-12.rounded-lg.bg-surface-container-highest
          .flex-1.min-w-0
            p.font-bold.text-on-surface.truncate(class="max-w-[140px] md:max-w-none")= topSong.song ? topSong.song.title : "Unknown title"
            p.text-xs.text-on-surface-variant.truncate= topSong.song ? topSong.song.artistNames : "Unknown artist"
          p.text-sm.font-bold.text-primary #{topSong.count} listens
      else
        p.text-on-surface-variant Bạn chưa có dữ liệu nghe nhạc đủ để thống kê.

    // Listening History
    section.mt-16.px-6.max-w-7xl.mx-auto.mb-20(class="md:px-12")
      h2.text-2xl.font-bold.tracking-tight.mb-8(class="md:text-3xl") Recent History
      div.bg-surface-container-low.rounded-xl.overflow-hidden.shadow-2xl
        div.grid.items-center.px-6.py-4.border-b.font-bold.uppercase.tracking-wider.text-on-surface-variant(
          class="grid-cols-[3rem_2fr_1fr_1fr] border-outline-variant/10 text-[10px]"
        )
          span #
          span Track
          span Artist
          span.text-right Duration

        if recentHistory && recentHistory.length
          div(class="divide-y divide-outline-variant/5")
            each item, idx in recentHistory
              div.grid.items-center.px-6.py-4.transition-colors.group(
                class="grid-cols-[3rem_2fr_1fr_1fr] hover:bg-surface-container-high"
              )
                div.text-on-surface-variant= idx + 1
                div.flex.items-center.gap-4
                  if item.song && item.song.coverImage
                    img.w-10.h-10.rounded-lg.object-cover(src=item.song.coverImage alt=item.song.title || "Album art")
                  else
                    .w-10.h-10.rounded-lg.bg-surface-container-highest
                  div
                    //- Chỉ dùng hàm, bỏ truncate của CSS
                    p.font-bold.text-on-surface= truncateText(item.song ? item.song.title : "Unknown title", 15)
                    p.text-xs.text-on-surface-variant= item.listenedAtFromNow
                div.text-on-surface-variant= item.song ? item.song.artistNames : "Unknown artist"
                div.text-on-surface-variant.text-right #{item.song && item.song.duration ? `${Math.floor(item.song.duration / 60)}:${String(item.song.duration % 60).padStart(2, '0')}` : "--:--"}
        else
          div.px-6.py-6.text-on-surface-variant Bạn chưa có lịch sử nghe nhạc.

  //- Các thành phần CỐ ĐỊNH 
  // BottomNavBar (Mobile Only)
  nav.fixed.bottom-0.left-0.w-full.h-20.flex.justify-around.items-center.px-4.glass.backdrop-blur-2xl.z-50.rounded-t-xl.border-t(
    class="md:hidden pb-safe dark:bg-surface-variant/40 border-outline-variant/20 shadow-[0_-20px_40px_rgba(0,0,0,0.4)]"
  )
    a.flex.flex-col.items-center.justify-center.text-on-surface-variant.rounded-xl.px-4.py-2(href="#" class="dark:text-on-surface-variant hover:bg-surface-container-highest/30")
      span.material-symbols-outlined home
      span.font-bold.uppercase.tracking-wider.mt-1(class="text-[10px]") Home
    a.flex.flex-col.items-center.justify-center.text-secondary.rounded-xl.px-4.py-2.scale-110(href="#" class="dark:text-secondary drop-shadow-[0_0_10px_rgba(68,226,205,0.3)] hover:bg-surface-container-highest/30")
      span.material-symbols-outlined person
      span.font-bold.uppercase.tracking-wider.mt-1(class="text-[10px]") Profile

  